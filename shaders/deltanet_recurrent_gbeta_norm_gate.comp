#version 450

#extension GL_EXT_shader_explicit_arithmetic_types_float16 : enable

// Fused DeltaNet: g/beta computation + recurrent decode + RMSNorm-gated output.
// Combines deltanet_recurrent_gbeta.comp + deltanet_norm_gate.comp into one
// dispatch, eliminating the intermediate output→norm round-trip.
//
// Per head h:
//   g[h]    = -exp(a_log[h]) * softplus(a[h] + dt_bias[h])
//   beta[h] = sigmoid(b[h])
//   state   = state * exp(g)
//   kv_mem  = state^T @ key
//   delta   = (value - kv_mem) * beta
//   state  += key ⊗ delta
//   raw_out = state^T @ query
//   norm    = RMSNorm(raw_out)
//   output  = fp16(weight * norm) * SiLU(z)
//
// Buffer layout (8 bindings):
//   [0] dn_a:           [num_heads] float16 — projected a values
//   [1] dn_b:           [num_heads] float16 — projected b values
//   [2] a_log_bias:     packed [layer][head][2] float32
//         For layer l, head h:
//           a_log   at offset (l * num_heads + h) * 2 + 0
//           dt_bias at offset (l * num_heads + h) * 2 + 1
//   [3] Q:              [num_heads * k_dim] fp16 — query vectors (L2-normed)
//   [4] KV/out:         [num_heads * k_dim] K fp16 + [num_heads * v_dim] V fp16
//                       Output overwrites V section.
//   [5] dn_state:       [num_heads * k_dim * v_dim] fp32 recurrent state
//   [6] dn_z:           [num_heads * v_dim] fp16 — gate input for SiLU
//   [7] delta_norm:     [v_dim] fp32 — RMSNorm weight
//
// Dispatch: one workgroup per head, 128 invocations each.
// Push constants: num_heads, k_dim, v_dim, state_total, q_scale_bits, layer_idx, epsilon_bits

layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0, std430) readonly buffer ABuf {
    float16_t d[];
} a_buf;

layout(set = 0, binding = 1, std430) readonly buffer BBuf {
    float16_t d[];
} b_buf;

layout(set = 0, binding = 2, std430) readonly buffer ABufBias {
    float d[];
} ab_buf;

layout(set = 0, binding = 3, std430) readonly buffer QueryBuffer {
    float16_t data[];
} q_buf;

layout(set = 0, binding = 4, std430) buffer KVOutputBuffer {
    float16_t data[];
} kv_buf;

layout(set = 0, binding = 5, std430) buffer StateBuffer {
    float d[];
} state_buf;

layout(set = 0, binding = 6, std430) readonly buffer GateBuffer {
    float16_t data[];
} z_buf;

layout(set = 0, binding = 7, std430) readonly buffer NormWeightBuffer {
    float d[];
} norm_w_buf;

layout(push_constant) uniform Params {
    uint num_heads;      // 16
    uint k_dim;          // 128
    uint v_dim;          // 128
    uint state_total;    // num_heads * k_dim * v_dim
    uint q_scale_bits;   // float bits for 1/sqrt(k_dim)
    uint layer_idx;      // DeltaNet layer index for a_log_bias lookup
    uint epsilon_bits;   // float bits for RMSNorm epsilon
} params;

shared float s_k[128];
shared float s_v[128];
shared float s_q[128];
shared float s_kv_mem[128];
shared float s_delta[128];
shared float s_output[128];
shared float s_g;
shared float s_beta;
shared float s_norm_factor;

void main() {
    uint head = gl_WorkGroupID.x;
    uint lid = gl_LocalInvocationID.x;

    if (head >= params.num_heads) return;

    uint k = params.k_dim;
    uint v = params.v_dim;
    uint state_offset = head * k * v;

    // --- Phase 1: Compute g and beta inline from a, b, a_log_bias ---
    if (lid == 0u) {
        float a_val = float(a_buf.d[head]);
        float b_val = float(b_buf.d[head]);

        uint ab_base = (params.layer_idx * params.num_heads + head) * 2u;
        float a_log   = ab_buf.d[ab_base];
        float dt_bias = ab_buf.d[ab_base + 1u];

        // g = -exp(a_log) * softplus(a + dt_bias)
        float sp = log(1.0 + exp(a_val + dt_bias));
        s_g = -exp(a_log) * sp;

        // beta = sigmoid(b)
        s_beta = 1.0 / (1.0 + exp(-b_val));
    }
    barrier();

    float g_h = s_g;
    float beta_h = s_beta;

    // --- Phase 2: Load q, k, v into shared memory ---
    if (lid < k) {
        s_q[lid] = float(q_buf.data[head * k + lid]) * uintBitsToFloat(params.q_scale_bits);
        s_k[lid] = float(kv_buf.data[head * k + lid]);
    }
    if (lid < v) {
        s_v[lid] = float(kv_buf.data[params.num_heads * k + head * v + lid]);
    }
    barrier();

    // --- Phase 3: Decay state by exp(g) ---
    float exp_g = exp(g_h);
    uint state_elems = k * v;
    uint elems_per_inv = (state_elems + 127u) / 128u;

    for (uint e = 0u; e < elems_per_inv; ++e) {
        uint idx = lid * elems_per_inv + e;
        if (idx < state_elems) {
            state_buf.d[state_offset + idx] *= exp_g;
        }
    }
    barrier();

    // --- Phase 4: kv_mem = state^T @ k -> [v_dim] ---
    if (lid < v) {
        float sum = 0.0;
        for (uint i = 0u; i < k; ++i) {
            sum += state_buf.d[state_offset + i * v + lid] * s_k[i];
        }
        s_kv_mem[lid] = sum;
    }
    barrier();

    // --- Phase 5: delta = (v - kv_mem) * beta ---
    if (lid < v) {
        s_delta[lid] = (s_v[lid] - s_kv_mem[lid]) * beta_h;
    }
    barrier();

    // --- Phase 6: state += k ⊗ delta ---
    for (uint e = 0u; e < elems_per_inv; ++e) {
        uint idx = lid * elems_per_inv + e;
        if (idx < state_elems) {
            uint i = idx / v;
            uint j = idx % v;
            state_buf.d[state_offset + idx] += s_k[i] * s_delta[j];
        }
    }
    barrier();

    // --- Phase 7: output = state^T @ q -> [v_dim] ---
    if (lid < v) {
        float sum = 0.0;
        for (uint i = 0u; i < k; ++i) {
            sum += state_buf.d[state_offset + i * v + lid] * s_q[i];
        }
        s_output[lid] = sum;
    }
    barrier();

    // --- Phase 8: RMS-normalize the 128-wide output vector ---
    float eps = uintBitsToFloat(params.epsilon_bits);

    // Each invocation accumulates partial sum-of-squares over its share of v_dim.
    // With 128 invocations and v_dim == 128, elems_per_inv_norm == 1.
    uint elems_per_inv_norm = (v + 127u) / 128u;
    float local_sq = 0.0;
    for (uint i = 0u; i < elems_per_inv_norm; ++i) {
        uint d = lid * elems_per_inv_norm + i;
        if (d < v) {
            float val = s_output[d];
            local_sq += val * val;
        }
    }

    // Tree-reduce across 128 lanes using shared memory.
    // Reuse s_kv_mem as scratch since Phase 7 no longer needs it.
    s_kv_mem[lid] = local_sq;
    barrier();

    for (uint stride = 64u; stride > 0u; stride >>= 1u) {
        if (lid < stride) {
            s_kv_mem[lid] += s_kv_mem[lid + stride];
        }
        barrier();
    }

    if (lid == 0u) {
        s_norm_factor = inversesqrt(s_kv_mem[0] / float(v) + eps);
    }
    barrier();

    // --- Phase 9: Apply weight * norm, fp16 round, SiLU(z), write to V/output ---
    if (lid < v) {
        float normed = s_output[lid] * s_norm_factor;
        float w = norm_w_buf.d[lid];  // fp32 weight
        float z = float(z_buf.data[head * v + lid]);
        float silu = z / (1.0 + exp(-z));
        // HF Qwen3_5RMSNormGated: cast weight * norm(hidden) to fp16 before
        // multiplying by the fp32 SiLU gate.
        float weighted = float(float16_t(w * normed));
        kv_buf.data[params.num_heads * k + head * v + lid] = float16_t(weighted * silu);
    }
}
